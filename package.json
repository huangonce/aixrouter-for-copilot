{
  "name": "aixrouter-for-copilot",
  "displayName": "AIXRouter for Copilot",
  "description": "Use AIXRouter models directly from the GitHub Copilot Chat model picker. BYOK, vision-capable models, thinking mode, and agent tools.",
  "version": "0.1.19",
  "packageManager": "pnpm@9.15.9",
  "publisher": "aixrouter",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huangonce/aixrouter-for-copilot.git"
  },
  "homepage": "https://github.com/huangonce/aixrouter-for-copilot#readme",
  "bugs": {
    "url": "https://github.com/huangonce/aixrouter-for-copilot/issues"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=20",
    "pnpm": ">=9 <10"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "aixrouter",
    "aixrouter",
    "magic-router",
    "copilot",
    "github copilot",
    "agent",
    "chat",
    "openai",
    "vision",
    "reasoning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "aixrouter",
        "displayName": "AIXRouter"
      }
    ],
    "commands": [
      {
        "command": "aixrouter.setBaseUrl",
        "title": "AIXRouter: Set Base URL"
      },
      {
        "command": "aixrouter.setApiKey",
        "title": "AIXRouter: Set API Key"
      },
      {
        "command": "aixrouter.clearApiKey",
        "title": "AIXRouter: Clear API Key"
      },
      {
        "command": "aixrouter.refreshModels",
        "title": "AIXRouter: Refresh Models"
      },
      {
        "command": "aixrouter.openSettings",
        "title": "AIXRouter: Open Settings"
      }
    ],
    "configuration": {
      "title": "AIXRouter for Copilot",
      "properties": {
        "aixrouter.baseUrl": {
          "type": "string",
          "default": "https://api.aixrouter.com",
          "description": "AIXRouter gateway base URL. Claude chat requests use /claude/v1; other requests use /openai/v1."
        },
        "aixrouter.models": {
          "type": "array",
          "default": [],
          "markdownDescription": "Optional pinned model list. Leave empty to load from `{baseUrl}/openai/v1/models`. Each item accepts `id`, `name`, `family`, `version`, `maxInputTokens`, `maxOutputTokens`, `toolCalling`, `vision`, `thinking`, and `supportsReasoningEffort`.",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "AIXRouter API model id."
              },
              "name": {
                "type": "string",
                "description": "Display name in Copilot Chat."
              },
              "family": {
                "type": "string",
                "description": "Model family label."
              },
              "version": {
                "type": "string",
                "description": "Model version label."
              },
              "maxInputTokens": {
                "type": "number",
                "description": "Maximum input context tokens."
              },
              "maxOutputTokens": {
                "type": "number",
                "description": "Maximum output tokens."
              },
              "toolCalling": {
                "type": "boolean",
                "default": true
              },
              "vision": {
                "type": "boolean",
                "default": false
              },
              "thinking": {
                "type": "boolean",
                "default": false
              },
              "supportsReasoningEffort": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high",
                    "xhigh",
                    "max"
                  ]
                },
                "description": "Optional reasoning effort values supported by this model. Leave empty to use the default Low/Medium/High/Extra High/Max set."
              }
            }
          }
        },
        "aixrouter.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum completion tokens. 0 means provider default."
        },
        "aixrouter.temperature": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "maximum": 2,
          "description": "Optional request temperature."
        },
        "aixrouter.reasoningEffort": {
          "type": "string",
          "default": "high",
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "description": "Reasoning effort for models that support thinking mode."
        },
        "aixrouter.enrichPublicModelMetadata": {
          "type": "boolean",
          "default": true,
          "description": "Enrich model metadata from the public AIXRouter model catalog for supported AIXRouter and AgileRouter base URLs."
        },
        "aixrouter.compatibilityMode": {
          "type": "string",
          "default": "stable",
          "enum": [
            "stable",
            "full"
          ],
          "enumDescriptions": [
            "Send a conservative OpenAI-compatible request shape and omit optional AIXRouter routing/thinking hints on OpenAI-compatible routes.",
            "Send all supported AIXRouter request options, including context_window and reasoning_effort when selected."
          ],
          "description": "Controls optional request fields sent to AIXRouter. Stable mode can improve compatibility with OpenAI-compatible upstream routes."
        },
        "aixrouter.openAIStreamFallback": {
          "type": "boolean",
          "default": true,
          "description": "Retry OpenAI-compatible chat requests once with stream disabled when the upstream explicitly rejects streaming or SSE responses."
        },
        "aixrouter.debug": {
          "type": "boolean",
          "default": false,
          "description": "Write request and stream diagnostics to the AIXRouter output channel. Prompt text is not logged."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "sync-models": "node scripts/sync-model-metadata.mjs",
    "compile": "pnpm run clean && tsc -p ./",
    "watch": "pnpm run clean && tsc -watch -p ./",
    "package": "pnpm run compile && pnpm exec vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.mjs",
    "release:prepare": "node scripts/release.mjs --publish",
    "validate:litellm": "tsx scripts/validate-litellm.mjs"
  },
  "devDependencies": {
    "@types/node": "20.19.1",
    "@types/vscode": "1.116.0",
    "@vscode/vsce": "3.6.0",
    "tsx": "^4.22.4",
    "typescript": "5.8.3",
    "vitest": "^4.1.9"
  }
}
