{
  "name": "aixrouter-for-copilot",
  "displayName": "AIX Router for Copilot",
  "description": "Use AIX Router models directly from the GitHub Copilot Chat model picker. BYOK, vision-capable models, thinking mode, and agent tools.",
  "version": "0.0.1",
  "publisher": "aixrouter",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aixrouter/aixrouter-for-copilot.git"
  },
  "homepage": "https://github.com/aixrouter/aixrouter-for-copilot#readme",
  "bugs": {
    "url": "https://github.com/aixrouter/aixrouter-for-copilot/issues"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=20"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "aixrouter",
    "copilot",
    "github copilot",
    "agent",
    "chat",
    "openai",
    "vision",
    "reasoning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "aixrouter",
        "displayName": "AIX Router"
      }
    ],
    "commands": [
      {
        "command": "aixrouter-copilot.setBaseUrl",
        "title": "AIX Router: Set Base URL"
      },
      {
        "command": "aixrouter-copilot.setApiKey",
        "title": "AIX Router: Set API Key"
      },
      {
        "command": "aixrouter-copilot.clearApiKey",
        "title": "AIX Router: Clear API Key"
      },
      {
        "command": "aixrouter-copilot.refreshModels",
        "title": "AIX Router: Refresh Models"
      },
      {
        "command": "aixrouter-copilot.openSettings",
        "title": "AIX Router: Open Settings"
      }
    ],
    "configuration": {
      "title": "AIX Router for Copilot",
      "properties": {
        "aixrouter-copilot.baseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible AIX Router base URL, for example https://api.example.com/openai/v1."
        },
        "aixrouter-copilot.models": {
          "type": "array",
          "default": [],
          "markdownDescription": "Optional pinned model list. Leave empty to load from `/models`. Each item accepts `id`, `name`, `family`, `version`, `maxInputTokens`, `maxOutputTokens`, `toolCalling`, `vision`, and `thinking`.",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "AIX Router API model id."
              },
              "name": {
                "type": "string",
                "description": "Display name in Copilot Chat."
              },
              "family": {
                "type": "string",
                "description": "Model family label."
              },
              "version": {
                "type": "string",
                "description": "Model version label."
              },
              "maxInputTokens": {
                "type": "number",
                "description": "Maximum input context tokens."
              },
              "maxOutputTokens": {
                "type": "number",
                "description": "Maximum output tokens."
              },
              "toolCalling": {
                "type": "boolean",
                "default": true
              },
              "vision": {
                "type": "boolean",
                "default": false
              },
              "thinking": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "aixrouter-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum completion tokens. 0 means provider default."
        },
        "aixrouter-copilot.temperature": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "maximum": 2,
          "description": "Optional request temperature."
        },
        "aixrouter-copilot.reasoningEffort": {
          "type": "string",
          "default": "high",
          "enum": [
            "low",
            "medium",
            "high",
            "max"
          ],
          "description": "Reasoning effort for models that support thinking mode."
        },
        "aixrouter-copilot.debug": {
          "type": "boolean",
          "default": false,
          "description": "Write request and stream diagnostics to the AIX Router output channel. Prompt text is not logged."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.1",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.8.3"
  }
}
