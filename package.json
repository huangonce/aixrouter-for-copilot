{
  "name": "magic-router-for-copilot",
  "displayName": "Magic Router for Copilot",
  "description": "Use Magic Router models directly from the GitHub Copilot Chat model picker. BYOK, vision-capable models, thinking mode, and agent tools.",
  "version": "0.1.4",
  "packageManager": "pnpm@9.15.9",
  "publisher": "aixrouter",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aixrouter/magic-router-for-copilot.git"
  },
  "homepage": "https://github.com/aixrouter/magic-router-for-copilot#readme",
  "bugs": {
    "url": "https://github.com/aixrouter/magic-router-for-copilot/issues"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=20",
    "pnpm": ">=9 <10"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "aixrouter",
    "magic router",
    "magic-router",
    "copilot",
    "github copilot",
    "agent",
    "chat",
    "openai",
    "vision",
    "reasoning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "magicrouter",
        "displayName": "Magic Router"
      }
    ],
    "commands": [
      {
        "command": "magicrouter.setBaseUrl",
        "title": "Magic Router: Set Base URL"
      },
      {
        "command": "magicrouter.setApiKey",
        "title": "Magic Router: Set API Key"
      },
      {
        "command": "magicrouter.clearApiKey",
        "title": "Magic Router: Clear API Key"
      },
      {
        "command": "magicrouter.refreshModels",
        "title": "Magic Router: Refresh Models"
      },
      {
        "command": "magicrouter.openSettings",
        "title": "Magic Router: Open Settings"
      }
    ],
    "configuration": {
      "title": "Magic Router for Copilot",
      "properties": {
        "magicrouter.baseUrl": {
          "type": "string",
          "default": "https://api.aixrouter.com",
          "description": "Magic Router gateway base URL. Claude chat requests use /claude/v1; other requests use /openai/v1."
        },
        "magicrouter.models": {
          "type": "array",
          "default": [],
          "markdownDescription": "Optional pinned model list. Leave empty to load from `/models`. Each item accepts `id`, `name`, `family`, `version`, `maxInputTokens`, `maxOutputTokens`, `toolCalling`, `vision`, and `thinking`.",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Magic Router API model id."
              },
              "name": {
                "type": "string",
                "description": "Display name in Copilot Chat."
              },
              "family": {
                "type": "string",
                "description": "Model family label."
              },
              "version": {
                "type": "string",
                "description": "Model version label."
              },
              "maxInputTokens": {
                "type": "number",
                "description": "Maximum input context tokens."
              },
              "maxOutputTokens": {
                "type": "number",
                "description": "Maximum output tokens."
              },
              "toolCalling": {
                "type": "boolean",
                "default": true
              },
              "vision": {
                "type": "boolean",
                "default": false
              },
              "thinking": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "magicrouter.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum completion tokens. 0 means provider default."
        },
        "magicrouter.temperature": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "maximum": 2,
          "description": "Optional request temperature."
        },
        "magicrouter.reasoningEffort": {
          "type": "string",
          "default": "high",
          "enum": [
            "low",
            "medium",
            "high",
            "max"
          ],
          "description": "Reasoning effort for models that support thinking mode."
        },
        "magicrouter.enrichPublicModelMetadata": {
          "type": "boolean",
          "default": true,
          "description": "Enrich model metadata from the public Magic Router model catalog for supported AIXRouter and AgileRouter base URLs."
        },
        "magicrouter.debug": {
          "type": "boolean",
          "default": false,
          "description": "Write request and stream diagnostics to the Magic Router output channel. Prompt text is not logged."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "pnpm run clean && tsc -p ./",
    "watch": "pnpm run clean && tsc -watch -p ./",
    "package": "pnpm run compile && pnpm exec vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "20.19.1",
    "@types/vscode": "1.116.0",
    "@vscode/vsce": "3.6.0",
    "typescript": "5.8.3"
  }
}
